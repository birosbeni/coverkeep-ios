    "rule.at.legalGuarantee": {
      "localizations": {
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Gewährleistung: az eladó az átadástól számított 2 évig felel az olyan hibákért, amelyek már az átadáskor megvoltak. Az első évben vélelmezett, hogy a hiba kezdettől megvolt. Az igények a 2 év lejárta után még 3 hónapig érvényesíthetők."
          }
        }
      }
    },
    "rule.at.withdrawal": {
      "localizations": {
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Rücktrittsrecht: az online vásárolt terméket az átvételtől számított 14 napon belül indoklás nélkül visszaküldheted. Naptári napokban számolva. Egyes termékek kivételek."
          }
        }
      }
    },
    "rule.de.legalGuarantee": {
      "localizations": {
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Gewährleistung: az eladó a kézbesítéstől számított 2 évig felel az olyan hibákért, amelyek már az átadáskor megvoltak. Az első évben vélelmezett, hogy a hiba kezdettől megvolt — az ellenkezőjét az eladónak kell bizonyítania."
          }
        }
      }
    },
    "rule.de.withdrawal": {
      "localizations": {
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Widerrufsrecht: az online vásárolt terméket az átvételtől számított 14 napon belül indoklás nélkül visszaküldheted. Naptári napokban számolva. Egyes termékek kivételek."
          }
        }
      }
    },
    "rule.eu.legalGuarantee": {
      "localizations": {
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "EU-szintű minimum: az eladó az átvételtől számított 2 évig felel az olyan hibákért, amelyek már az átadáskor megvoltak. Az első évben vélelmezett, hogy a hiba kezdettől megvolt — az ellenkezőjét az eladónak kell bizonyítania. A nemzeti jog ennél többet is adhat."
          }
        }
      }
    },
    "rule.eu.withdrawal": {
      "localizations": {
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az online vásárolt terméket az átvételtől számított 14 napon belül indoklás nélkül visszaküldheted. Itt naptári napokban számoljuk; ha az utolsó nap munkaszüneti napra esik, a jog a következő munkanapig is járhat. Egyes termékek kivételek (egyedi készítésű termékek, felbontott higiéniai cikkek stb.)."
          }
        }
      }
    },
    "rule.hu.legalGuarantee": {
      "localizations": {
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kellékszavatosság: az eladó az átadástól számított 2 évig felel az olyan hibákért, amelyek már az átadáskor megvoltak. Az első évben vélelmezett, hogy a hiba kezdettől megvolt — az ellenkezőjét az eladónak kell bizonyítania."
          }
        }
      }
    },
    "rule.hu.mandatoryWarranty": {
      "localizations": {
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Jótállás: a legalább 10 000 Ft-os új tartós fogyasztási cikkekre kötelező jótállás jár — 250 000 Ft-ig 2 év, felette 3 év. A rendelet mellékletében felsorolt termékkörökre vonatkozik (a legtöbb elektronikai és háztartási cikk), ezért ellenőrizd, hogy a terméked ide tartozik-e. A kellékszavatossággal ellentétben a jótállás alatt végig az eladónak kell bizonyítania, hogy a termék hibátlan volt."
          }
        }
      }
    },
    "rule.hu.withdrawal": {
      "localizations": {
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Elállási jog: az online vásárolt terméket az átvételtől számított 14 napon belül indoklás nélkül visszaküldheted. Naptári napokban számolva. Egyes termékek kivételek (egyedi készítésű termékek, felbontott higiéniai cikkek stb.)."
          }
        }
      }
    },
